# Yellowstone gRPC stream provider (provider-agnostic — SolInfra/PublicNode/etc.)
# PublicNode is tokenless; SolInfra will require GRPC_X_TOKEN once enabled.
GRPC_ENDPOINT=https://solana-yellowstone-grpc.publicnode.com:443
GRPC_X_TOKEN=

# Unary RPC fallback (leader schedule refresh etc. — never the confirmation path)
RPC_URL=https://api.mainnet-beta.solana.com

# Jito block engine (global; regional endpoints also valid)
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf

# Burner wallet (gitignored path; generate via packages/core/scripts/generate-keypair.mjs)
WALLET_KEYPAIR_PATH=./keys/burner.json

# AI agent (Phase 5)
ANTHROPIC_API_KEY=
